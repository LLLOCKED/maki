generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MODERATOR
  USER
}

enum TeamRole {
  owner
  admin
  member
}

enum TeamJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NovelType {
  JAPAN
  KOREA
  CHINA
  ENGLISH
  ORIGINAL
}

enum NovelStatus {
  ONGOING
  COMPLETED
  SUSPENDED
}

enum TranslationStatus {
  TRANSLATING
  DROPPED
  COMPLETED
  HIATUS
}

enum BookmarkStatus {
  reading
  planned
  completed
  dropped
}

enum ReportTargetType {
  NOVEL
  CHAPTER
  COMMENT
  FORUM_COMMENT
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole @default(USER)
  lastSeen      DateTime?
  isBanned      Boolean   @default(false)
  banReason     String?
  bannedAt      DateTime?
  bannedBy      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  comments      Comment[]
  teamMemberships TeamMembership[]
  teamJoinRequests TeamJoinRequest[]
  ratings       Rating[]
  collections   Collection[]
  bookmarks     Bookmark[]
  forumTopics   ForumTopic[]
  forumComments ForumComment[]
  forumTopicVotes ForumTopicVote[]
  commentVotes CommentVote[]
  forumCommentVotes ForumCommentVote[]
  novels      Novel[]     @relation("UserNovels")
  warnings     UserWarning[] @relation("UserWarnings")
  activityLogs AdminActivityLog[]
  issuedWarnings UserWarning[] @relation("WarningIssuer")
  novelViews    NovelView[]
  notifications Notification[]
  favorites    Favorite[]
  teamFollows   TeamFollow[]
  contentReports ContentReport[] @relation("ReportAuthor")
  resolvedReports ContentReport[] @relation("ReportResolver")
}

model Collection {
  id        String   @id @default(cuid())
  name      String
  userId    String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  novels  Novel[]   @relation("CollectionNovels")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // 'NEW_CHAPTER'
  novelId   String
  chapterId String
  teamId    String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel   Novel   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  team    Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  novelId   String
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  slug    String      @unique
  novels  NovelTag[]
}

model NovelTag {
  novelId String
  tagId   String

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([novelId, tagId])
}

model Rating {
  id        String   @id @default(cuid())
  value     Int      // 1-5
  userId    String
  novelId   String
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
}

model Bookmark {
  id              String   @id @default(cuid())
  userId           String
  novelId          String
  status           BookmarkStatus
  readingPosition  Int?     // chapter number where user stopped reading
  readingProgress  Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  @@unique([userId, novelId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ForumCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String   @default("#6366f1")
  order       Int      @default(0)
  topics      ForumTopic[]
  createdAt   DateTime @default(now())
}

model ForumTopic {
  id          String   @id @default(cuid())
  title       String
  content     String
  userId      String
  categoryId  String
  novelId     String?
  moderationStatus ModerationStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  comments    ForumComment[]
  votes       ForumTopicVote[]
  novel      Novel?      @relation(fields: [novelId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([userId])
  @@index([novelId])
}

model ForumTopicVote {
  id        String   @id @default(cuid())
  value     Int      // 1 for upvote, -1 for downvote
  userId    String
  topicId   String
  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
}

model ForumComment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  topicId   String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic   ForumTopic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  parent  ForumComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies ForumComment[] @relation("CommentReplies")
  votes   ForumCommentVote[]
  reports ContentReport[]

  @@index([topicId])
  @@index([userId])
  @@index([parentId])
}

model ForumCommentVote {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment ForumComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model Publisher {
  id      String    @id @default(cuid())
  name    String    @unique
  slug    String    @unique
  novels  NovelPublisher[]
}

model Author {
  id      String    @id @default(cuid())
  name    String    @unique
  slug    String    @unique
  novels  NovelAuthor[]
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  avatarUrl   String?
  bannerUrl   String?
  createdAt   DateTime @default(now())
  members     TeamMembership[]
  joinRequests TeamJoinRequest[]
  chapters    Chapter[]
  notifications Notification[]
  followers     TeamFollow[]

  @@index([slug])
}

model TeamMembership {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      TeamRole @default(member)
  joinedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model TeamJoinRequest {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  status    TeamJoinRequestStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId, status])
  @@index([userId, status])
}

model TeamFollow {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

model Novel {
  id               String   @id @default(cuid())
  title            String
  originalName     String?
  slug             String   @unique
  description      String
  coverUrl         String?
  type             NovelType @default(ORIGINAL)
  status           NovelStatus @default(ONGOING)
  translationStatus TranslationStatus @default(TRANSLATING)
  releaseYear      Int?
  averageRating    Float   @default(0)
  viewCount        Int     @default(0)
  moderationStatus ModerationStatus @default(PENDING)
  sourceUrl        String?
  isExplicit       Boolean  @default(false)
  contentWarnings String[] @default([]) // ['violence', 'gore', 'sexual', 'psychological', 'self-harm']
  donationUrl      String?  // посилання на донати для ORIGINAL тайтлів
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?
  authorId         String?  // For ORIGINAL type novels - the author user

  chapters     Chapter[]
  genres       NovelGenre[]
  publishers   NovelPublisher[]
  authors      NovelAuthor[]
  comments     Comment[]
  ratings      Rating[]
  tags         NovelTag[]
  bookmarks    Bookmark[]
  inCollections Collection[]  @relation("CollectionNovels")
  forumTopics   ForumTopic[]
  views        NovelView[]
  author       User?     @relation("UserNovels", fields: [authorId], references: [id], onDelete: SetNull)
  notifications Notification[]
  favorites    Favorite[]
  reports      ContentReport[]

  @@index([slug])
  @@index([authorId])
  @@index([deletedAt])
}

model NovelPublisher {
  novelId     String
  publisherId String

  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  publisher Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  @@id([novelId, publisherId])
}

model NovelAuthor {
  novelId  String
  authorId String

  novel  Novel   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([novelId, authorId])
}

model Chapter {
  id        String   @id @default(cuid())
  title     String
  number    Float
  volume    Int?     // том (необов'язково)
  content   String
  novelId   String
  teamId    String?
  moderationStatus ModerationStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  novel    Novel     @relation(fields: [novelId], references: [id], onDelete: Cascade)
  team     Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  comments Comment[]
  notifications Notification[]
  reports ContentReport[]

  @@index([novelId])
  @@index([teamId])
  @@index([volume])
  @@index([deletedAt])
}

model ContentReport {
  id          String           @id @default(cuid())
  targetType  ReportTargetType
  reason      String
  details     String?
  status      ReportStatus     @default(OPEN)
  userId      String
  novelId     String?
  chapterId   String?
  commentId   String?
  forumCommentId String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  resolvedAt  DateTime?
  resolvedBy  String?

  user      User     @relation("ReportAuthor", fields: [userId], references: [id], onDelete: Cascade)
  resolver  User?    @relation("ReportResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)
  novel     Novel?   @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter   Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  forumComment ForumComment? @relation(fields: [forumCommentId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([targetType])
  @@index([userId])
  @@index([novelId])
  @@index([chapterId])
  @@index([commentId])
  @@index([forumCommentId])
}

model Genre {
  id     String      @id @default(cuid())
  name   String      @unique
  slug   String      @unique
  novels NovelGenre[]
}

model NovelGenre {
  novelId String
  genreId String

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([novelId, genreId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  novelId   String?
  chapterId String?
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  novel    Novel?    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter  Chapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")
  votes    CommentVote[]
  reports  ContentReport[]

  @@index([novelId])
  @@index([chapterId])
  @@index([parentId])
}

model CommentVote {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model UserWarning {
  id        String   @id @default(cuid())
  userId    String
  reason    String
  issuedBy  String   // admin mod userId
  createdAt DateTime @default(now())

  user   User @relation("UserWarnings", fields: [userId], references: [id], onDelete: Cascade)
  issuer User @relation("WarningIssuer", fields: [issuedBy], references: [id])
}

model NovelView {
  id        String   @id @default(cuid())
  novelId   String
  ipAddress String
  userId    String?
  viewedDate DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  viewedAt  DateTime @default(now())

  novel Novel @relation(fields: [novelId], references: [id], onDelete: Cascade)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([novelId, ipAddress, viewedDate])
  @@index([novelId])
  @@index([ipAddress])
  @@index([viewedDate])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  description String?
  posterUrl   String?
  linkUrl     String   // URL to navigate to (novel page, forum topic, etc.)
  linkType    String   // 'novel', 'forum', 'page', 'external'
  tag         String   // 'news', 'popular', 'attention', 'new', 'featured'
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // WARN_USER, BAN_USER, UNBAN_USER, APPROVE_NOVEL, REJECT_NOVEL, etc.
  targetId   String?
  targetType String?  // 'user', 'novel', 'chapter'
  details    String?  // JSON with additional info
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
